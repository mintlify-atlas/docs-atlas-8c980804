            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Core API",
            "pages": [
              "core/elements",
              "core/collections",
              "core/conditions",
              "core/selectors",
              "core/actions"
            ]
          },
          {
