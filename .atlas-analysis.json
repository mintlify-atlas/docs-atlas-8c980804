              "configuration/browser",
              "configuration/timeouts-and-assertions"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/file-downloads",
              "advanced/page-objects",
              "advanced/javascript-and-shadow-dom",
              "advanced/screenshots-and-reports"
            ]
          }
        ]
      },
      {
        "tab": "Modules",
        "groups": [
          {
            "group": "Test Runners",
            "pages": [
              "modules/junit5",
              "modules/junit4",
              "modules/testng"
            ]
          },
          {
            "group": "Remote & Grid",
            "pages": [
