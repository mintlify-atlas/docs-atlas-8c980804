{
  "projectType": "sdk-library",
  "projectName": "Selenide",
  "projectDescription": "A Java UI testing framework built on top of Selenium WebDriver that provides a concise fluent API, natural-language assertions, and automatic waiting for AJAX-based web applications.",
  "theme": "palm",
  "primaryColor": "#0595f8",
  "lightColor": "#a104a0",
  "darkColor": "#f1a83e",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
